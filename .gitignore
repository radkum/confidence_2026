# ── Deploy outputs (regenerated by deploy/build.bat + deploy/package.bat) ───
deploy/confidence-release/
deploy/confidence-release.zip
deploy/logs/
deploy/reports/
deploy/ramon-client.exe
deploy/*.cer

# Sign-time generated test certificate stays out of repo
**/confidence_test.cer
**/sysmon-km/DriverCertificate.cer

# ── Confidence runtime data (lives in C:\ProgramData but in case copied) ───
ml_samples_count.txt
ramsi-com.log

# ── External sample collections (downloaded by user, see samples/INSTRUKCJE_POBIERANIA.md) ──
# Keep our own authored samples (Obfuscated_Malicious_Powershell/26, 27, 28...)
# Exclude cloned 3rd-party repos with their own .git history
samples/malicious/nishang/
samples/malicious/PowerSploit/
samples/amsi-bypass/
samples/obfuscation-tools/Invoke-Obfuscation/
samples/benign/

# Obfuscated_Malicious_Powershell: only the demo three (26, 27, 28) are committed.
# Other samples in there come from various 3rd-party repos with their own licenses.
samples/Obfuscated_Malicious_Powershell/*
!samples/Obfuscated_Malicious_Powershell/26_amsi_provider_disruption.ps1
!samples/Obfuscated_Malicious_Powershell/27_amsi_provider_disruption_evasive.ps1
!samples/Obfuscated_Malicious_Powershell/28_etw_bypass.ps1

